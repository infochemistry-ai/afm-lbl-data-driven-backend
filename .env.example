# App
APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://afm:afm@localhost:5432/afm_lbl

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./storage
EXPORT_LOCAL_ROOT=./exports

# S3 (only if STORAGE_BACKEND=s3)
S3_BUCKET=
S3_PREFIX=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PRESIGN_EXPIRES_SEC=3600
